# ---- Servidor ----
PORT=3000
NODE_ENV=development
# URL pública base (para QR y links). En prod: https://fidelizacion.getitchile.cl
APP_URL=

# ---- Base de datos (PostgreSQL / Supabase) ----
# Supabase → Project Settings → Database → Connection string (Session pooler).
# Ej: postgresql://postgres.xxxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=
# TLS a la base. Supabase lo exige (true). Para Postgres local usa false.
DB_SSL=false
# Verificación del certificado (seguro por defecto). Para verificar la cadena de
# Supabase, descarga su CA (Project Settings → Database → SSL) y apunta aquí:
DB_CA_CERT=
# Último recurso si no puedes proveer la CA (permite MITM — evítalo):
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=10

# ---- Sesión ----
SESSION_DURATION_MS=28800000

# ---- Passwords de seed (sobre-escribir en producción) ----
# Si se omiten, se usan los valores por defecto históricos (solo para dev).
SEED_SUPERADMIN_PASSWORD=
SEED_ADMIN_PASSWORD=
SEED_CASHIER_PASSWORD=
